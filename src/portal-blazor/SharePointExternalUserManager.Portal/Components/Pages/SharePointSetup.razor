@page "/admin/sharepoint-setup"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using SharePointExternalUserManager.Portal.Models
@attribute [Authorize]
@inject Services.ApiClient ApiClient
@inject NavigationManager Navigation
@inject ILogger<SharePointSetup> Logger

<PageTitle>SharePoint Setup - ClientSpace</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="mb-0">
                <span class="bi bi-shield-check me-2 text-primary"></span>
                SharePoint Setup
            </h2>
            <p class="text-muted">Complete these steps to connect your SharePoint tenant and grant required permissions.</p>
        </div>
    </div>

    @if (_permissionsMissing)
    {
        <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
            <span class="bi bi-exclamation-triangle-fill me-2 fs-5"></span>
            <div>
                <strong>Action Required:</strong> One or more Microsoft Graph permissions are missing.
                Features that rely on SharePoint or Microsoft Graph will be unavailable until all permissions are granted.
                <a href="#permissions-section" class="alert-link ms-1">Review permissions below.</a>
            </div>
        </div>
    }

    <!-- Step 1: Install SPFx Package -->
    <div class="card shadow-sm mb-4">
        <div class="card-header d-flex align-items-center">
            <span class="badge bg-primary rounded-pill me-2">Step 1</span>
            <h5 class="mb-0">Install the ClientSpace SPFx Package</h5>
        </div>
        <div class="card-body">
            <p>
                Upload and deploy the <strong>ClientSpace</strong> SharePoint Framework (SPFx) package
                (<code>sharepoint-external-user-manager.sppkg</code>) to your tenant App Catalog.
                This makes the ClientSpace web parts available in SharePoint.
            </p>

            <div class="alert alert-info">
                <span class="bi bi-info-circle-fill me-2"></span>
                <strong>You need to be a SharePoint Administrator</strong> to upload apps to the tenant App Catalog.
            </div>

            <h6 class="mt-3">Instructions</h6>
            <ol>
                <li>
                    Download or build the latest <code>.sppkg</code> file.
                    The package is located at
                    <code>src/client-spfx/sharepoint/solution/sharepoint-external-user-manager.sppkg</code>
                    after running <code>gulp bundle --ship &amp;&amp; gulp package-solution --ship</code>.
                </li>
                <li>
                    Open your SharePoint Admin Center and go to
                    <strong>More features → Apps → App Catalog</strong>, or navigate directly to:<br/>
                    <a href="https://YOUR_TENANT-admin.sharepoint.com/_layouts/15/tenantAppCatalog.aspx/manageApps"
                       target="_blank" rel="noopener noreferrer" class="text-break">
                        https://&lt;tenant&gt;-admin.sharepoint.com/_layouts/15/tenantAppCatalog.aspx/manageApps
                    </a>
                </li>
                <li>Click <strong>Upload</strong> and select the <code>.sppkg</code> file.</li>
                <li>When prompted, check <strong>"Make this solution available to all sites in the organization"</strong> and click <strong>Deploy</strong>.</li>
                <li>Return here and proceed to Step 2.</li>
            </ol>

            <div class="alert alert-secondary mt-3">
                <span class="bi bi-book me-2"></span>
                <strong>Need help?</strong>
                See the
                <a href="https://learn.microsoft.com/sharepoint/use-app-catalog" target="_blank" rel="noopener noreferrer">
                    official SharePoint App Catalog documentation
                </a>.
            </div>
        </div>
    </div>

    <!-- Step 2: Grant Microsoft Graph Permissions -->
    <div class="card shadow-sm mb-4" id="permissions-section">
        <div class="card-header d-flex align-items-center">
            <span class="badge bg-primary rounded-pill me-2">Step 2</span>
            <h5 class="mb-0">Grant Microsoft Graph &amp; SharePoint API Permissions</h5>
        </div>
        <div class="card-body">
            <p>
                ClientSpace requires the following Microsoft Graph and SharePoint permissions to
                manage external users, read site information, and configure sharing settings.
                A <strong>Global Administrator</strong> or <strong>SharePoint Administrator</strong> must grant these permissions.
            </p>

            <!-- Permission Status List -->
            @if (_loadingPermissions)
            {
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                    Checking permission status&hellip;
                </div>
            }
            else
            {
                <div class="table-responsive mb-4">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Permission</th>
                                <th>Purpose</th>
                                <th class="text-center" style="width:120px">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var perm in _requiredPermissions)
                            {
                                var isGranted = _grantedPermissions.Contains(perm.Name, StringComparer.OrdinalIgnoreCase);
                                <tr>
                                    <td><code>@perm.Name</code></td>
                                    <td class="text-muted small">@perm.Description</td>
                                    <td class="text-center">
                                        @if (isGranted)
                                        {
                                            <span class="badge bg-success">
                                                <span class="bi bi-check-circle-fill me-1"></span>Granted
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                <span class="bi bi-x-circle-fill me-1"></span>Missing
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!string.IsNullOrEmpty(_permissionsError))
                {
                    <div class="alert alert-warning">
                        <span class="bi bi-exclamation-triangle-fill me-2"></span>
                        <strong>Could not check live permission status.</strong>
                        @_permissionsError
                        <br/>
                        <small>Use the button below to grant permissions anyway.</small>
                    </div>
                }

                @if (_allPermissionsGranted)
                {
                    <div class="alert alert-success">
                        <span class="bi bi-check-circle-fill me-2"></span>
                        <strong>All required permissions are granted.</strong>
                        Your tenant is fully connected to ClientSpace.
                    </div>
                }
            }

            <!-- Grant / Re-grant button -->
            @if (_initiatingConsent)
            {
                <div class="text-center py-2">
                    <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                    Redirecting to Microsoft consent page&hellip;
                </div>
            }
            else
            {
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-primary" @onclick="InitiateConsent">
                        <span class="bi bi-shield-check me-2"></span>
                        @(_allPermissionsGranted ? "Re-grant Permissions" : "Grant Permissions")
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="CheckPermissions" disabled="@_loadingPermissions">
                        <span class="bi bi-arrow-clockwise me-2"></span>
                        Refresh Status
                    </button>
                </div>
            }

            @if (!string.IsNullOrEmpty(_consentError))
            {
                <div class="alert alert-danger mt-3">
                    <span class="bi bi-exclamation-triangle-fill me-2"></span>
                    <strong>Error:</strong> @_consentError
                </div>
            }

            <div class="alert alert-secondary mt-4">
                <span class="bi bi-info-circle me-2"></span>
                <strong>What happens when you click "Grant Permissions"?</strong><br/>
                You will be redirected to the Microsoft sign-in page where an administrator can
                review and approve the listed permissions on behalf of your organization.
                After approval you are returned here automatically.
                <br/><br/>
                <strong>Cannot automate this step?</strong> An administrator can also grant
                consent directly in the
                <a href="https://entra.microsoft.com/#view/Microsoft_AAD_IAM/EnterpriseApplications" target="_blank" rel="noopener noreferrer">
                    Microsoft Entra admin center
                </a>
                under <strong>Enterprise Applications → your app → Permissions → Grant admin consent</strong>.
            </div>
        </div>
    </div>

    <!-- Step 3: Verify Setup -->
    <div class="card shadow-sm mb-4">
        <div class="card-header d-flex align-items-center">
            <span class="badge @(_allPermissionsGranted ? "bg-success" : "bg-secondary") rounded-pill me-2">Step 3</span>
            <h5 class="mb-0">Verify Your Setup</h5>
        </div>
        <div class="card-body">
            @if (_allPermissionsGranted)
            {
                <div class="alert alert-success mb-3">
                    <span class="bi bi-check-circle-fill me-2"></span>
                    <strong>Setup complete!</strong>
                    All permissions are in place. You can now use all ClientSpace features.
                </div>
                <a href="/dashboard" class="btn btn-primary me-2">
                    <span class="bi bi-speedometer2 me-2"></span>Go to Dashboard
                </a>
            }
            else
            {
                <p class="text-muted">
                    Complete Steps 1 and 2 above, then use the <strong>Refresh Status</strong> button to
                    confirm that all permissions are granted before proceeding.
                </p>
                <p>
                    <strong>Features blocked until permissions are granted:</strong>
                </p>
                <ul>
                    <li>Inviting and managing external users</li>
                    <li>Provisioning SharePoint client spaces</li>
                    <li>Reading SharePoint site and document library data</li>
                    <li>Configuring SharePoint external sharing settings</li>
                </ul>
            }
        </div>
    </div>
</div>

@code {
    private bool _loadingPermissions = true;
    private bool _initiatingConsent = false;
    private bool _allPermissionsGranted = false;
    private bool _permissionsMissing = false;
    private string? _permissionsError;
    private string? _consentError;
    private List<string> _grantedPermissions = new();

    private static readonly List<(string Name, string Description)> _requiredPermissions =
    [
        ("User.Read.All",           "Read all user profiles — required to view and manage external users invited to your SharePoint sites."),
        ("Sites.ReadWrite.All",     "Manage SharePoint sites — required to configure sharing settings and manage site permissions."),
        ("Sites.FullControl.All",   "Full control of SharePoint — required for advanced external sharing configuration."),
        ("Directory.Read.All",      "Read directory data — required to read organization and group information."),
    ];

    [Parameter]
    [SupplyParameterFromQuery(Name = "admin_consent")]
    public string? AdminConsent { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "error")]
    public string? ConsentCallbackError { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "error_description")]
    public string? ConsentCallbackErrorDescription { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(ConsentCallbackError))
        {
            _consentError = $"Authorization failed: {ConsentCallbackError}. {ConsentCallbackErrorDescription}";
        }

        await CheckPermissions();
    }

    private async Task CheckPermissions()
    {
        _loadingPermissions = true;
        _permissionsError = null;

        try
        {
            var result = await ApiClient.ValidatePermissionsAsync();
            if (result != null)
            {
                _grantedPermissions = result.GrantedPermissions ?? new List<string>();
                _allPermissionsGranted = result.HasRequiredPermissions;
                _permissionsMissing = !result.HasRequiredPermissions;
            }
            else
            {
                _permissionsError = "The API did not return a permissions status. Ensure the API is running and reachable.";
                _permissionsMissing = true;
            }
        }
        catch (Services.ApiNotConfiguredException)
        {
            _permissionsError = "The API server URL is not configured. Please set the 'ApiSettings__BaseUrl' application setting.";
            _permissionsMissing = true;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not retrieve permission status from API");
            _permissionsError = "Could not reach the API to check live permission status. Ensure the API is deployed and running.";
            _permissionsMissing = true;
        }
        finally
        {
            _loadingPermissions = false;
        }
    }

    private async Task InitiateConsent()
    {
        _initiatingConsent = true;
        _consentError = null;

        try
        {
            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            var redirectUri = $"{baseUrl}/admin/sharepoint-setup";
            var response = await ApiClient.ConnectTenantAsync(redirectUri);

            if (response != null && !string.IsNullOrEmpty(response.AuthorizationUrl))
            {
                Navigation.NavigateTo(response.AuthorizationUrl, forceLoad: true);
            }
            else
            {
                _consentError = "Failed to generate the authorization URL. Please try again or contact support.";
            }
        }
        catch (Services.ApiNotConfiguredException)
        {
            _consentError = "The API server URL is not configured. Please contact your administrator to set the 'ApiSettings__BaseUrl' application setting.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initiate admin consent from SharePoint Setup page");
            _consentError = "An unexpected error occurred. Please try again or contact support.";
        }
        finally
        {
            _initiatingConsent = false;
        }
    }
}
